---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const [featured, ...rest] = posts;

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const readingMinutes = (body: string) => Math.max(1, Math.round(body.split(/\s+/).length / 220));
---

<Layout
  title="Food & Mood Insights | Alimor Blog"
  description="Practical guides on food journaling, symptom tracking, and mindful eating — from the maker of Alimor, the food journal without calorie counting."
>

<div class="min-h-screen flex flex-col">

<!-- Navigation -->
<nav class="fixed top-0 w-full z-50 glass safe-area-top">
  <div class="max-w-6xl mx-auto px-5 sm:px-6 py-3 sm:py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5">
      <img src="/icon.png" alt="Alimor" class="w-9 h-9 sm:w-10 sm:h-10 rounded-[10px] sm:rounded-xl shadow-sm" />
      <span class="text-lg sm:text-xl font-semibold text-alimor-purple tracking-tight">Alimor</span>
    </a>
    <a
      href="https://apps.apple.com/app/food-journal-alimor/id6756018932"
      class="touch-target flex items-center justify-center btn-hover"
    >
      <img src="/Download_on_the_App_Store_Badge.svg" alt="Download on the App Store" class="h-9 sm:h-10" />
    </a>
  </div>
</nav>

<!-- Hero -->
<header class="pt-28 sm:pt-36 pb-10 sm:pb-14 px-5 sm:px-6 relative overflow-hidden">
  <div class="absolute -top-40 -left-32 w-[480px] h-[480px] rounded-full bg-alimor-purple/10 blur-3xl pointer-events-none" aria-hidden="true"></div>
  <div class="absolute top-24 -right-40 w-[520px] h-[520px] rounded-full bg-alimor-purple-light/10 blur-3xl pointer-events-none" aria-hidden="true"></div>

  <div class="max-w-6xl mx-auto relative z-10 text-center">
    <h1 class="animate-fade-in-up stagger-1 text-4xl sm:text-5xl font-bold tracking-tight mb-4">
      Food &amp; Mood <span class="text-alimor-purple">Insights</span>
    </h1>
    <p class="animate-fade-in-up stagger-2 text-lg sm:text-xl text-alimor-text-light max-w-2xl mx-auto leading-relaxed">
      Practical guides on food journaling, symptom tracking, and mindful eating — without the calorie obsession.
    </p>
  </div>
</header>

<main class="flex-1 px-5 sm:px-6 pb-16 sm:pb-24">
  <div class="max-w-6xl mx-auto">

    {featured && (
      <a
        href={`/blog/${featured.slug}/`}
        class="animate-fade-in-up stagger-3 group block glass-card rounded-3xl p-7 sm:p-10 mb-8 sm:mb-10 transition-all duration-300 hover:shadow-xl hover:-translate-y-1"
      >
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="inline-block bg-alimor-purple text-white text-xs font-semibold px-3.5 py-1.5 rounded-full">Latest</span>
          {featured.data.tags.slice(0, 2).map((tag) => (
            <span class="inline-block bg-alimor-purple/10 text-alimor-purple text-xs font-semibold px-3.5 py-1.5 rounded-full">{tag}</span>
          ))}
        </div>
        <h2 class="text-2xl sm:text-[2rem] font-bold tracking-tight leading-tight mb-3 group-hover:text-alimor-purple transition-colors">
          {featured.data.title}
        </h2>
        <p class="text-alimor-text-light text-base sm:text-lg leading-relaxed max-w-3xl mb-5">
          {featured.data.description}
        </p>
        <div class="flex items-center gap-3 text-sm text-alimor-text-light">
          <time datetime={featured.data.pubDate.toISOString()}>{formatDate(featured.data.pubDate)}</time>
          <span aria-hidden="true">·</span>
          <span>{readingMinutes(featured.body)} min read</span>
          <span class="ml-auto text-alimor-purple font-semibold inline-flex items-center gap-1.5 group-hover:gap-2.5 transition-all">
            Read article
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </span>
        </div>
      </a>
    )}

    {rest.length > 0 && (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
        {rest.map((post) => (
          <a
            href={`/blog/${post.slug}/`}
            class="group block bg-white rounded-3xl border border-gray-100 p-6 sm:p-7 transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
          >
            {post.data.tags.length > 0 && (
              <span class="inline-block bg-alimor-purple/10 text-alimor-purple text-xs font-semibold px-3 py-1 rounded-full mb-4">
                {post.data.tags[0]}
              </span>
            )}
            <h2 class="text-lg sm:text-xl font-bold tracking-tight leading-snug mb-2.5 group-hover:text-alimor-purple transition-colors">
              {post.data.title}
            </h2>
            <p class="text-alimor-text-light text-[15px] leading-relaxed mb-4">{post.data.description}</p>
            <div class="flex items-center gap-2.5 text-sm text-alimor-text-light">
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              <span aria-hidden="true">·</span>
              <span>{readingMinutes(post.body)} min read</span>
            </div>
          </a>
        ))}
      </div>
    )}

    {posts.length === 0 && (
      <p class="text-center text-alimor-text-light py-16">First articles coming soon.</p>
    )}
  </div>
</main>

<!-- Footer -->
<footer class="py-10 px-5 sm:px-6 bg-alimor-text text-white safe-area-bottom">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-400">
    <div class="flex items-center gap-2.5">
      <img src="/icon.png" alt="Alimor" class="w-8 h-8 rounded-lg" />
      <span class="text-white font-semibold">Alimor</span>
    </div>
    <div class="flex items-center gap-5">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <a href="/support/" class="hover:text-white transition-colors">Support</a>
      <a href="/privacy/" class="hover:text-white transition-colors">Privacy</a>
    </div>
    <p>&copy; 2026 Alimor</p>
  </div>
</footer>

</div>

</Layout>
